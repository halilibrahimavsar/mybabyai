# Virtual Environment
venv/
.venv/
env/
bin/
lib/
lib64/
include/
pyvenv.cfg

# Python Cache
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.coverage
htmlcov/

# Logs
logs/*.log
*.log

# Data Artifacts
data/*.db
data/mybabyai.db
data/chroma/
*.sqlite3

# Model Artifacts
# Global ignores for large weight files
*.pt
*.bin
*.safetensors
*.model
*.ckpt

# Keep model structure but ignore heavy weights
!codemind/
!codemind/**
codemind/**/*.pt
codemind/**/*.bin
codemind/**/*.safetensors

# Ensure all tokenizer and configuration files are tracked
!**/tokenizer/
!**/tokenizer/**
!config.json
!tokenizer_config.json
!vocab.json
!tokenizer.json
!special_tokens_map.json
!generation_config.json

# Other potential model folders
models/fine_tuned/
models/CodeMind-*/
checkpoint-*/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
